{
  "name": "jerry-can-spirits-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:legacy": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "indexnow": "tsx scripts/submit-indexnow.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^6.3.0",
    "@sentry/nextjs": "^10.63.0",
    "@shopify/storefront-api-client": "^1.0.10",
    "@swc/helpers": "^0.5.23",
    "aws4fetch": "^1.0.20",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "mapbox-gl": "^3.25.0",
    "next": "15.5.20",
    "next-sanity": "^13.1.1",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "read-excel-file": "^9.2.0",
    "sanity": "^6.3.0",
    "styled-components": "^6.4.3",
    "tailwind-merge": "^3.6.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^15.5.19",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^24.13.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "hosted-git-info": "^7.0.0",
    "glob": "^13.0.0",
    "node-domexception": "^2.0.2",
    "undici": "^7.0.0",
    "fast-xml-parser": ">=5.7.0",
    "uuid": ">=14.0.0"
  },
  "browserslist": [
    "chrome >= 96",
    "firefox >= 96",
    "safari >= 15",
    "edge >= 96",
    "not dead",
    "not IE 11",
    "not op_mini all"
  ]
