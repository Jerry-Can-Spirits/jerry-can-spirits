# Resend — trade application admin emails
RESEND_API_KEY=
TRADE_APPLICATIONS_EMAIL=trade@jerrycanspirits.co.uk

# Klaviyo trade list for marketing opt-in
KLAVIYO_TRADE_LIST_ID=

# Cloudflare R2 S3-compatible API (for presigning download URLs in admin emails)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=

# Anthropic API key (Pour IQ AI recommendations)
ANTHROPIC_API_KEY=

# GA4 Measurement Protocol — server-side purchase attribution from the Shopify
# order webhook. SERVER-ONLY: do NOT prefix with NEXT_PUBLIC_ (that would ship
# the api_secret in the client bundle). The measurement id is the same G- id
# used client-side (G-6VJL06YBW2); the api_secret is created in GA4 Admin →
# Data Streams → Measurement Protocol API secrets. Leave both blank to keep the
# send dark (it skips and logs until configured).
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Server Actions — stable encryption key (REQUIRED at build time).
# Without a fixed key, Next.js generates a random one per build, so action
# tokens minted by one Cloudflare Worker version are rejected by another
# ("Server Action ... was not found on the server") during/after rollouts.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set the SAME value here, in .env.local, and in the Cloudflare Workers Build
# environment variables (so git-triggered prod builds use it too).
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
